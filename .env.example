# OMNIUS AI Assistant - Environment Configuration
# Copy this to .env and fill with your actual credentials

# Server
NODE_ENV=development
PORT=3000
HOST=localhost
LOG_LEVEL=debug

# AI Models - Free APIs
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
HUGGINGFACE_API_KEY=hf_YOUR_HF_API_KEY_HERE

# Ollama (Local - no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=true
OLLAMA_MODEL=llama2

# Voice Processing
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_KEY_FILE=./config/google-cloud-key.json
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Email & Calendar (Google)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Gmail IMAP/SMTP (Alternative)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Database
DATABASE_URL=sqlite:./data/omnius.db
DATABASE_BACKUP_PATH=./data/backups

# Session & Security
SESSION_SECRET=your-super-secret-session-key-change-this
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRY=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Processing
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
TEMP_DIR=./temp

# Web Scraping
SCRAPER_TIMEOUT=30000
SCRAPER_USER_AGENT=Mozilla/5.0 (OMNIUS AI Assistant)

# Real-Time
REDIS_URL=redis://localhost:6379
WEBSOCKET_ENABLED=true

# Monitoring & Logging
SENTRY_DSN=your-sentry-dsn-here
LOG_FILE_PATH=./logs/omnius.log

# Features
ENABLE_VOICE=true
ENABLE_AUTOMATION=true
ENABLE_WEB_SCRAPING=true
ENABLE_CODE_EXECUTION=true
ENABLE_FILE_PROCESSING=true
ENABLE_EMAIL_INTEGRATION=true
ENABLE_CALENDAR_INTEGRATION=true

# Development
DEBUG=omnius:*
MOCK_RESPONSES=false
DRY_RUN=false
