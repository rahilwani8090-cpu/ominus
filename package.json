    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "socket.io": "^4.7.1",
    "pg": "^8.11.3",
    "better-sqlite3": "^9.0.0",
    "axios": "^1.5.0",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.9.6",
    "node-cron": "^3.0.2",
    "uuid": "^9.0.1",
    "joi": "^17.11.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "pino-http": "^8.5.1",
    "prom-client": "^15.0.0",
    "bull": "^4.11.4",
    "redis": "^4.6.11",
    "@anthropic-ai/sdk": "^0.4.0",
    "groq-sdk": "^0.3.0",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5",
    "papaparse": "^5.4.1",
    "cheerio": "^1.0.0-rc.12",
    "puppeteer": "^21.4.1",
    "tesseract.js": "^5.0.4",
