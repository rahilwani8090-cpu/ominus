{
  "name": "omnius-ai-assistant",
  "version": "1.0.0",
  "description": "OMNIUS - Real AI Assistant like JARVIS. Production-grade automation system with multi-model AI, real voice I/O, and intelligent automation.",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "node server/AdvancedServer.js",
    "dev": "nodemon server/AdvancedServer.js",
    "dev:old": "nodemon server/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "cypress run",
    "lint": "eslint .",
    "build": "npm run lint && npm run test",
    "setup": "node scripts/setup.js",
    "db:migrate": "node scripts/migrate.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f omnius",
    "ollama:start": "ollama serve",
    "ollama:pull": "ollama pull llama2 && ollama pull mistral && ollama pull neural-chat",
    "metrics": "open http://localhost:9090",
    "grafana": "open http://localhost:3001"
  },
  "keywords": [
    "ai",
    "assistant",
    "jarvis",
    "automation",
    "groq",
    "ollama",
    "voice",
    "real-time"
  ],
  "author": "Your Name",
  "license": "MIT",
