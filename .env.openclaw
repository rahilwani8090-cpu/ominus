# ============================================================================
# OMNIUS Phase 5 - OpenClaw Integration Environment Configuration
# ============================================================================
# Copy this to .env and configure with your actual values

# ============================================================================
# OpenClaw Gateway
# ============================================================================
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
OPENCLAW_WORKSPACE=/home/user/.openclaw

# ============================================================================
# Voice Integration (ElevenLabs)
# ============================================================================
# Get API key from: https://elevenlabs.io/app/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=Rachel

# Google Speech-to-Text
# Set up credentials: https://console.cloud.google.com
GOOGLE_STT_KEY=

# ============================================================================
# Channel Credentials
# ============================================================================

# WhatsApp (Baileys)
WHATSAPP_CREDENTIALS=

# Telegram
TELEGRAM_BOT_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Discord
DISCORD_BOT_TOKEN=

# Microsoft Teams
TEAMS_BOT_ID=
TEAMS_BOT_PASSWORD=

# Google Chat
GOOGLE_CHAT_WEBHOOK=

# Signal (signal-cli)
SIGNAL_CLI_PATH=/usr/bin/signal-cli

# iMessage/BlueBubbles
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_API_KEY=

# WeChat
WECHAT_CREDENTIALS=

# Matrix
MATRIX_HOMESERVER=https://matrix.org
MATRIX_ACCESS_TOKEN=

# Mattermost
MATTERMOST_URL=https://mattermost.example.com
MATTERMOST_BOT_TOKEN=

# Feishu (DingTalk)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# LINE
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# IRC
IRC_SERVER=irc.libera.chat
IRC_PORT=6667
IRC_NICK=omnius-bot

# Zalo
ZALO_OA_ID=
ZALO_SECRET_KEY=

# Synology Chat
SYNOLOGY_CHAT_URL=
SYNOLOGY_CHAT_TOKEN=

# Tlon (Urbit)
URBIT_SHIP_URL=
URBIT_CODE=

# Twitch
TWITCH_BOT_TOKEN=
TWITCH_CLIENT_ID=

# Nostr
NOSTR_PRIVATE_KEY=
NOSTR_RELAY_URLS=wss://relay.damus.io

# Nextcloud Talk
NEXTCLOUD_URL=
NEXTCLOUD_TOKEN=

# ============================================================================
# Core OMNIUS Configuration
# ============================================================================

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database
DB_TYPE=sqlite
DATABASE_URL=omnius.db

# Redis (for context memory, job queue, sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# AI Models Configuration
# ============================================================================

# Ollama (Primary - Local LLM, completely offline)
OLLAMA_ENABLED=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Groq (Free tier, very fast)
# Get API key from: https://console.groq.com
GROQ_API_KEY=

# OpenAI (GPT-4, best quality but costs money)
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude, excellent reasoning)
# Get API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# xAI (Grok, new model)
XAI_API_KEY=

# ============================================================================
# Automation Services
# ============================================================================

# Gmail
GMAIL_CREDENTIALS=

# Google Calendar
CALENDAR_CREDENTIALS=

# GitHub
GITHUB_TOKEN=

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_SELF_LEARNING=true
ENABLE_BROWSER_AUTOMATION=true
ENABLE_CONTEXT_MEMORY=true
ENABLE_VOICE=true
ENABLE_CANVAS=true
ENABLE_SKILLS=true

# ============================================================================
# Monitoring
# ============================================================================

# Sentry (error tracking)
SENTRY_DSN=

# Prometheus (metrics)
PROMETHEUS_ENABLED=true

# ============================================================================
# Security
# ============================================================================

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT
JWT_SECRET=your-jwt-secret-change-this

# ============================================================================
# Advanced Options
# ============================================================================

# Max concurrent browser instances
MAX_BROWSER_INSTANCES=5

# Context memory size (messages to keep)
MAX_CONTEXT_SIZE=20

# Session TTL (30 days)
SESSION_TTL=2592000

# Max skills to load
MAX_SKILLS=5400

# Canvas update interval (ms)
CANVAS_UPDATE_INTERVAL=500

# ============================================================================
# Notes
# ============================================================================
# 
# 1. Copy this file to .env and configure your values
# 2. Never commit .env file with real API keys to Git
# 3. Ollama can work completely offline - it's the primary provider
# 4. Other LLM providers (Groq, OpenAI, etc) are optional fallbacks
# 5. Channel credentials are optional - only enable what you need
# 6. For production, use strong JWT secrets and secure tokens
#
